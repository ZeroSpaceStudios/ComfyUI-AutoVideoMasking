# AutoVideoMasking (AVM) — API Key Configuration
# Copy this file to .env and fill in whichever key(s) you use.
# The .env file is gitignored and will never be committed.

# Used when model_name is a bare Gemini slug (e.g. "gemini-3.1-pro-preview")
GEMINI_API_KEY=your_gemini_key_here

# Used when model_name starts with "openrouter:" (e.g. "openrouter:openai/gpt-4o")
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
